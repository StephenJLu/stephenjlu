# Rename this file from .dev.vars.example to .dev.vars and fill in your values.
# .dev.vars is git-ignored and never committed.

ENVIRONMENT=development

# This is a random string used for the session cookie for saving the preferred theme
SESSION_SECRET=KEEP_IT_SECRET_KEEP_IT_SAFE

# URL of the deployed SMTP relay worker (contact endpoint)
# For local dev you can run the relay server locally and use:
#   CONTACT_RELAY_URL=http://localhost:8788/relay/contact
CONTACT_RELAY_URL=https://relay.stephenjlu.com/relay/contact

# Shared secret token matching CONTACT_RELAY_TOKEN set on the relay worker.
# Leave blank if the relay worker has no token configured.
CONTACT_RELAY_TOKEN=replace-with-long-random-token

